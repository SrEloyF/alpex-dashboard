  </div>

  <script>
    window.addEventListener('beforeunload', () => {
      sessionStorage.setItem('alpex_scroll_pos', window.scrollY);
    });

    let leadActualId = null;

    function switchTab(tab) {
      const isSol = tab === 'solicitudes';
      document.getElementById('tab-solicitudes').classList.toggle('hidden', !isSol);
      document.getElementById('tab-newsletter').classList.toggle('hidden', isSol);

      const btnSol = document.getElementById('btn-sol');
      const btnNews = document.getElementById('btn-news');

      if (isSol) {
        btnSol.className = "px-5 py-2 rounded-lg bg-accent text-black font-bold flex items-center gap-2";
        btnNews.className = "px-5 py-2 rounded-lg border border-white/10 text-white hover:bg-white/5 flex items-center gap-2";
      } else {
        btnNews.className = "px-5 py-2 rounded-lg bg-accent text-black font-bold flex items-center gap-2";
        btnSol.className = "px-5 py-2 rounded-lg border border-white/10 text-white hover:bg-white/5 flex items-center gap-2";
      }

      const url = new URL(window.location);
      url.searchParams.set('tab', tab);
      window.history.replaceState({}, '', url);
    }

    document.addEventListener('DOMContentLoaded', () => {
      const scrollPos = sessionStorage.getItem('alpex_scroll_pos');

      if (scrollPos !== null) {
        window.scrollTo({
          top: parseInt(scrollPos, 10),
          behavior: 'auto'
        });
        sessionStorage.removeItem('alpex_scroll_pos');
      }
      const currentTab = "<%= query.tab || 'solicitudes' %>";
      switchTab(currentTab);
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
        closeModal();
      }
    });

    const columns = document.querySelectorAll('.sortable-list');
    columns.forEach(col => {
      new Sortable(col, {
        group: 'kanban',
        animation: 150,
        ghostClass: 'opacity-50',
        onEnd: async (evt) => {
          const itemEl = evt.item;
          const id = itemEl.getAttribute('data-id');
          const nuevoEstado = evt.to.getAttribute('data-status');

          if (evt.from === evt.to) return;

          try {
            const res = await fetch(`/solicitudes/${id}`, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ estado: nuevoEstado })
            });
            const data = await res.json();
            if (!data.ok) throw new Error(data.message);

            const circle = itemEl.querySelector('.estado-circle');
            const colorMap = {
              Nuevo: 'bg-blue-500',
              Contactado: 'bg-purple-500',
              Negociacion: 'bg-yellow-500',
              Cerrado: 'bg-green-500'
            };

            circle.classList.remove(
              'bg-blue-500',
              'bg-purple-500',
              'bg-yellow-500',
              'bg-green-500',
              'bg-gray-500'
            );

            circle.classList.add(colorMap[nuevoEstado] || 'bg-gray-500');
          } catch (error) {
            alert('Error al actualizar el estado: ', error);
            console.error(error);
            evt.from.appendChild(itemEl);
          }
        }
      });
    });

    const modal = document.getElementById('leadModal');
    const modalContent = document.getElementById('modalContent');

    function openModal(data) {
      leadActualId = data.id;

      document.getElementById('modalName').innerText = data.nombre_completo;
      document.getElementById('modalEmailSubtitle').innerText = data.correo;
      document.getElementById('modalEstado').innerText = data.estado;
      const interesLabels = {
        Reinos: 'Reinos de Gondor',
        Colinas: 'Colinas del Golf',
        Inversion: 'Quiero ser inversionista',
        Academia: 'Academia ALPEX'
      };

      document.getElementById('modalInteres').innerText = interesLabels[data.interes_principal] || data.interes_principal;
      document.getElementById('modalCorreo').innerText = data.correo;
      document.getElementById('modalTelefono').innerText = data.telefono;
      document.getElementById('modalFecha').innerText = new Date(data.fecha_registro).toLocaleString('es-PE');

      document.getElementById('modalMensaje').innerText = data.mensaje || 'Sin mensaje adicional proporcionado por el cliente.';
      document.getElementById('modalNotas').value = data.notas_internas || '';

      const cleanPhone = data.telefono.replace(/\D/g, '');
      document.getElementById('btnWhatsapp').href = `https://wa.me/${cleanPhone}?text=Hola%20${encodeURIComponent(data.nombre_completo)},%20te%20contacto%20de%20Alpex.`;
      document.getElementById('btnGmail').href = `https://mail.google.com/mail/?view=cm&fs=1&to=${data.correo}&su=Contacto%20Alpex`;

      modal.classList.remove('hidden');
      setTimeout(() => {
        modal.classList.remove('opacity-0');
        modalContent.classList.remove('scale-95');
      }, 10);
    }

    function closeModal() {
      modal.classList.add('opacity-0');
      modalContent.classList.add('scale-95');
      setTimeout(() => modal.classList.add('hidden'), 300);
      leadActualId = null;
    }

    async function guardarNotas() {
      if (!leadActualId) return;
      const btn = event.target;
      const notas = document.getElementById('modalNotas').value;

      const originalText = btn.innerText;
      btn.innerText = 'Guardando...';

      try {
        const res = await fetch(`/solicitudes/${leadActualId}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ notas_internas: notas })
        });

        if (res.ok) {
          btn.innerText = '¡Guardado!';
          btn.classList.add('bg-green-500', 'text-white');
          setTimeout(() => {
            btn.innerText = originalText;
            btn.classList.remove('bg-green-500', 'text-white');
          }, 2000);
        }
      } catch (error) {
        alert('Error al guardar la nota');
        btn.innerText = originalText;
      }
    }

    async function eliminarSolicitud() {
      if (!leadActualId) return;

      const confirmacion = confirm('¿Estás seguro de eliminar este lead permanentemente?');
      if (!confirmacion) return;

      const btn = document.getElementById('btnEliminar');
      btn.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" class="w-5 h-5 girar" fill="currentColor">
          <path d="M208 48a48 48 0 1 1 96 0 48 48 0 1 1 -96 0zm0 416a48 48 0 1 1 96 0 48 48 0 1 1 -96 0zM48 208a48 48 0 1 1 0 96 48 48 0 1 1 0-96zm368 48a48 48 0 1 1 96 0 48 48 0 1 1 -96 0zM75 369.1A48 48 0 1 1 142.9 437 48 48 0 1 1 75 369.1zM75 75A48 48 0 1 1 142.9 142.9 48 48 0 1 1 75 75zM437 369.1A48 48 0 1 1 369.1 437 48 48 0 1 1 437 369.1z"/>
        </svg>
        Eliminando...`;

      try {
        const res = await fetch(`/solicitudes/${leadActualId}`, { method: 'DELETE' });
        if (res.ok) {
          const card = document.querySelector(`div[data-id="${leadActualId}"]`);
          if (card) card.remove();

          closeModal();
        } else {
          alert('No se pudo eliminar');
          btn.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" class="w-5 h-5 inline-block align-middle" fill="currentColor">
              <path d="M232.7 69.9C237.1 56.8 249.3 48 263.1 48L377 48C390.8 48 403 56.8 407.4 69.9L416 96L512 96C529.7 96 544 110.3 544 128C544 145.7 529.7 160 512 160L128 160C110.3 160 96 145.7 96 128C96 110.3 110.3 96 128 96L224 96L232.7 69.9zM128 208L512 208L512 512C512 547.3 483.3 576 448 576L192 576C156.7 576 128 547.3 128 512L128 208zM216 272C202.7 272 192 282.7 192 296L192 488C192 501.3 202.7 512 216 512C229.3 512 240 501.3 240 488L240 296C240 282.7 229.3 272 216 272zM320 272C306.7 272 296 282.7 296 296L296 488C296 501.3 306.7 512 320 512C333.3 512 344 501.3 344 488L344 296C344 282.7 333.3 272 320 272zM424 272C410.7 272 400 282.7 400 296L400 488C400 501.3 410.7 512 424 512C437.3 512 448 501.3 448 488L448 296C448 282.7 437.3 272 424 272z"/>
            </svg>
            Eliminar`;
        }
      } catch (error) {
        console.error(error);
        alert('Error en el servidor al eliminar');
        btn.innerHTML = `
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" class="w-5 h-5 inline-block align-middle" fill="currentColor">
            <path d="M232.7 69.9C237.1 56.8 249.3 48 263.1 48L377 48C390.8 48 403 56.8 407.4 69.9L416 96L512 96C529.7 96 544 110.3 544 128C544 145.7 529.7 160 512 160L128 160C110.3 160 96 145.7 96 128C96 110.3 110.3 96 128 96L224 96L232.7 69.9zM128 208L512 208L512 512C512 547.3 483.3 576 448 576L192 576C156.7 576 128 547.3 128 512L128 208zM216 272C202.7 272 192 282.7 192 296L192 488C192 501.3 202.7 512 216 512C229.3 512 240 501.3 240 488L240 296C240 282.7 229.3 272 216 272zM320 272C306.7 272 296 282.7 296 296L296 488C296 501.3 306.7 512 320 512C333.3 512 344 501.3 344 488L344 296C344 282.7 333.3 272 320 272zM424 272C410.7 272 400 282.7 400 296L400 488C400 501.3 410.7 512 424 512C437.3 512 448 501.3 448 488L448 296C448 282.7 437.3 272 424 272z"/>
          </svg>
          Eliminar`;
      }
    }

    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });
  </script>
</body>

</html>