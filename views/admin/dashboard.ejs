        <button id="btnEliminar" onclick="eliminarSolicitud()"
          class="w-full sm:w-auto sm:flex-1 px-6 bg-transparent border border-red-500 text-red-500 hover:bg-red-500 hover:text-white font-semibold py-4 sm:py-3 rounded-xl flex items-center justify-center gap-2 transition text-base">
          
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640"
            class="w-6 h-6 md:w-7 md:h-7 shrink-0" fill="currentColor">
            <path d="M232.7 69.9C237.1 56.8 249.3 48 263.1 48L377 48C390.8 48 403 56.8 407.4 69.9L416 96L512 96C529.7 96 544 110.3 544 128C544 145.7 529.7 160 512 160L128 160C110.3 160 96 145.7 96 128C96 110.3 110.3 96 128 96L224 96L232.7 69.9zM128 208L512 208L512 512C512 547.3 483.3 576 448 576L192 576C156.7 576 128 547.3 128 512L128 208z"/>
          </svg>

          <span>Eliminar</span>
        </button>

