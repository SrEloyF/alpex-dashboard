<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8" />
  <title>Admin ALPEX</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>

  <style>
    :root {
      --bg: #0f1724;
      --card: linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0.01));
      --glass: rgba(255, 255, 255, 0.03);
      --accent-1: #C89D40;
      --accent-2: #E7C77A;
      --muted: #9aa4c7;
      --text: #eaf0ff;
      --success: #2ecc71;
      --danger: #ff6b6b;
      --modal-bg: #1a2234;
    }

    body {
      background-color: var(--bg);
      color: var(--text);
      font-family: sans-serif;
    }

    ::-webkit-scrollbar {
      display: none;
    }

    #modalContent::-webkit-scrollbar {
      display: block;
      width: 8px;
    }

    #modalContent::-webkit-scrollbar-thumb {
      background: rgba(255,255,255,0.3);
      border-radius: 8px;
    }

    #modalContent::-webkit-scrollbar-track {
      background: transparent;
    }

    .bg-glass {
      background: var(--glass);
    }

    .bg-accent {
      background-color: var(--accent-1);
    }

    .text-muted {
      color: var(--muted);
    }

    .text-accent {
      color: var(--accent-1);
    }

    .kanban-column {
      min-height: 400px;
    }

    @keyframes spin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }

    svg.girar {
      animation: spin 1s linear infinite;
      display: inline-block;
      vertical-align: middle;
    }
  </style>
</head>

<body class="flex flex-col min-h-screen">
  
  <header class="w-full bg-glass border-b border-white/10 px-6 py-4">
    <div class="flex items-center justify-between">
  
      <div class="flex items-center gap-4">
        <img 
          src="https://alpex-seven.vercel.app/assets/logo_alpex.png" 
          alt="ALPEX" 
          class="w-28 sm:w-32"
        >

        <div class="flex flex-col leading-tight">
          <span class="text-white text-lg font-semibold tracking-wide">
            Dashboard
          </span>
          <span class="hidden md:inline text-muted text-xs tracking-widest uppercase">
            Panel de administración
          </span>
        </div>
      </div>
  
      <a href="/logout"
        class="flex items-center gap-2 px-4 py-2 rounded bg-red-600 hover:bg-red-700 text-white hover:text-white transition">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" class="w-5 h-5" fill="currentColor">
          <path
            d="M569 337C578.4 327.6 578.4 312.4 569 303.1L425 159C418.1 152.1 407.8 150.1 398.8 153.8C389.8 157.5 384 166.3 384 176L384 256L272 256C245.5 256 224 277.5 224 304L224 336C224 362.5 245.5 384 272 384L384 384L384 464C384 473.7 389.8 482.5 398.8 486.2C407.8 489.9 418.1 487.9 425 481L569 337zM224 160C241.7 160 256 145.7 256 128C256 110.3 241.7 96 224 96L160 96C107 96 64 139 64 192L64 448C64 501 107 544 160 544L224 544C241.7 544 256 529.7 256 512C256 494.3 241.7 480 224 480L160 480C142.3 480 128 465.7 128 448L128 192C128 174.3 142.3 160 160 160L224 160z" />
        </svg>
        <span class="hidden sm:inline">Cerrar sesión</span>
      </a>
  
    </div>
  </header>

  <main class="flex-1 p-8">

    <div class="flex flex-col xl:flex-row xl:items-center xl:justify-between gap-6 mb-10">
    
      <div class="grid grid-cols-2 md:grid-cols-4 xl:flex xl:flex-wrap gap-3 md:gap-4">
    
        <div class="relative w-full xl:w-48
                  bg-gradient-to-br from-blue-900/40 to-blue-700/20 
                  backdrop-blur-xl border border-blue-500/20 
                  rounded-2xl
                  px-4 py-4 md:px-5 md:py-5 xl:px-6 xl:py-5
                  min-h-[90px] md:min-h-[110px]
                  shadow-lg shadow-blue-900/20
                  hover:scale-[1.03] transition-all duration-300">
    
          <p class="text-2xl md:text-3xl font-bold text-white">
            <%= solicitudesTotal %>
          </p>
          <p class="text-xs md:text-sm text-blue-300 mt-1">
            Total de Leads
          </p>
        </div>
    
        <div class="relative w-full xl:w-48
                  bg-gradient-to-br from-teal-900/40 to-emerald-700/20 
                  backdrop-blur-xl border border-emerald-500/20 
                  rounded-2xl
                  px-4 py-4 md:px-5 md:py-5 xl:px-6 xl:py-5
                  min-h-[90px] md:min-h-[110px]
                  shadow-lg shadow-emerald-900/20
                  hover:scale-[1.03] transition-all duration-300">
    
          <p class="text-2xl md:text-3xl font-bold text-white">
            <%= board.Contactado ? board.Contactado.total : 0 %>
          </p>
          <p class="text-xs md:text-sm text-emerald-300 mt-1">
            Contactados
          </p>
        </div>
    
        <div class="relative w-full xl:w-48
                  bg-gradient-to-br from-amber-900/40 to-orange-700/20 
                  backdrop-blur-xl border border-orange-500/20 
                  rounded-2xl
                  px-4 py-4 md:px-5 md:py-5 xl:px-6 xl:py-5
                  min-h-[90px] md:min-h-[110px]
                  shadow-lg shadow-orange-900/20
                  hover:scale-[1.03] transition-all duration-300">
    
          <p class="text-2xl md:text-3xl font-bold text-white">
            <%= board.Negociacion.total %>
          </p>
          <p class="text-xs md:text-sm text-orange-300 mt-1">
            En negociación
          </p>
        </div>
    
        <div class="relative w-full xl:w-48
                  bg-gradient-to-br from-purple-900/40 to-indigo-700/20 
                  backdrop-blur-xl border border-purple-500/20 
                  rounded-2xl
                  px-4 py-4 md:px-5 md:py-5 xl:px-6 xl:py-5
                  min-h-[90px] md:min-h-[110px]
                  shadow-lg shadow-purple-900/20
                  hover:scale-[1.03] transition-all duration-300">
    
          <p class="text-2xl md:text-3xl font-bold text-white">
            <%= board.Cerrado.total %>
          </p>
          <p class="text-xs md:text-sm text-purple-300 mt-1">
            Leads cerrados
          </p>
        </div>
    
      </div>
    
      <div class="flex bg-black/40 backdrop-blur-xl border border-white/10 
                      rounded-xl p-1 gap-2">
    
        <button onclick="switchTab('solicitudes')" id="btn-sol" class="flex items-center gap-2 px-5 py-2 rounded-lg
                     bg-lime-400 text-black font-semibold
                     shadow-md shadow-lime-500/30
                     transition-all duration-300">
    
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" class="w-4 h-4" fill="currentColor">
            <path
              d="M104 112C90.7 112 80 122.7 80 136L80 184C80 197.3 90.7 208 104 208L152 208C165.3 208 176 197.3 176 184L176 136C176 122.7 165.3 112 152 112L104 112zM256 128C238.3 128 224 142.3 224 160C224 177.7 238.3 192 256 192L544 192C561.7 192 576 177.7 576 160C576 142.3 561.7 128 544 128L256 128zM256 288C238.3 288 224 302.3 224 320C224 337.7 238.3 352 256 352L544 352C561.7 352 576 337.7 576 320C576 302.3 561.7 288 544 288L256 288zM256 448C238.3 448 224 462.3 224 480C224 497.7 238.3 512 256 512L544 512C561.7 512 576 497.7 576 480C576 462.3 561.7 448 544 448L256 448zM80 296L80 344C80 357.3 90.7 368 104 368L152 368C165.3 368 176 357.3 176 344L176 296C176 282.7 165.3 272 152 272L104 272C90.7 272 80 282.7 80 296zM104 432C90.7 432 80 442.7 80 456L80 504C80 517.3 90.7 528 104 528L152 528C165.3 528 176 517.3 176 504L176 456C176 442.7 165.3 432 152 432L104 432z" />
          </svg>
    
          Leads (<%= solicitudesTotal %>)
        </button>
    
        <button onclick="switchTab('newsletter')" id="btn-news" class="flex items-center gap-2 px-5 py-2 rounded-lg
                     text-gray-300 hover:text-white
                     hover:bg-white/5
                     transition-all duration-300">
    
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" class="w-4 h-4" fill="currentColor">
            <path
              d="M112 128C85.5 128 64 149.5 64 176C64 191.1 71.1 205.3 83.2 214.4L291.2 370.4C308.3 383.2 331.7 383.2 348.8 370.4L556.8 214.4C568.9 205.3 576 191.1 576 176C576 149.5 554.5 128 528 128L112 128zM64 260L64 448C64 483.3 92.7 512 128 512L512 512C547.3 512 576 483.3 576 448L576 260L377.6 408.8C343.5 434.4 296.5 434.4 262.4 408.8L64 260z" />
          </svg>
    
          Newsletter (<%= newsletterData.total %>)
        </button>
    
      </div>
    
    </div>

    <section id="tab-solicitudes">
      <form method="GET" action="/" class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8 bg-glass p-4 rounded-xl border border-white/10">
        <input type="hidden" name="tab" value="solicitudes">
        
        <input type="hidden" name="searchNews" value="<%= query.searchNews || '' %>">
        <input type="hidden" name="startNews" value="<%= query.startNews || '' %>">
        <input type="hidden" name="endNews" value="<%= query.endNews || '' %>">
        
        <input type="text" name="searchLeads" value="<%= query.searchLeads || '' %>" placeholder="Buscar lead..." class="bg-black/20 border border-white/10 p-3 rounded-lg text-sm text-white outline-none focus:border-accent-1">
        <input type="date" name="startLeads" value="<%= query.startLeads || '' %>" class="bg-black/20 border border-white/10 p-3 rounded-lg text-sm text-muted outline-none focus:border-accent-1">
        <input type="date" name="endLeads" value="<%= query.endLeads || '' %>" class="bg-black/20 border border-white/10 p-3 rounded-lg text-sm text-muted outline-none focus:border-accent-1">
        
        <div class="flex gap-2">
          <button type="submit" class="flex-1 bg-accent text-black font-bold rounded-lg py-3 hover:bg-yellow-500 transition">Filtrar Leads</button>
          <% if(query.searchLeads || query.startLeads) { %>
            <a href="/?tab=solicitudes" class="px-4 bg-white/10 text-white rounded-lg py-3 flex items-center hover:bg-white/20">
              <svg 
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 640 640"
                class="w-5 h-5 inline-block align-middle"
                fill="currentColor"
              >
                <path d="M183.1 137.4C170.6 124.9 150.3 124.9 137.8 137.4C125.3 149.9 125.3 170.2 137.8 182.7L275.2 320L137.9 457.4C125.4 469.9 125.4 490.2 137.9 502.7C150.4 515.2 170.7 515.2 183.2 502.7L320.5 365.3L457.9 502.6C470.4 515.1 490.7 515.1 503.2 502.6C515.7 490.1 515.7 469.8 503.2 457.3L365.8 320L503.1 182.6C515.6 170.1 515.6 149.8 503.1 137.3C490.6 124.8 470.3 124.8 457.8 137.3L320.5 274.7L183.1 137.4z"/>
              </svg>
            </a>
          <% } %>
        </div>
      </form>

      <% 
        const getPageUrl = (target, targetPage) => {
          let pNuevo = target === 'Nuevo' ? targetPage : (query.pageNuevo || 1);
          let pContactado = target === 'Contactado' ? targetPage : (query.pageContactado || 1);
          let pNeg = target === 'Negociacion' ? targetPage : (query.pageNegociacion || 1);
          let pCer = target === 'Cerrado' ? targetPage : (query.pageCerrado || 1);
          let pNews = target === 'Newsletter' ? targetPage : (query.newsletterPage || 1);
          
          let currentTab = target === 'Newsletter' ? 'newsletter' : (target ? 'solicitudes' : (query.tab || 'solicitudes'));
          
          return `?pageNuevo=${pNuevo}&pageContactado=${pContactado}&pageNegociacion=${pNeg}&pageCerrado=${pCer}&newsletterPage=${pNews}&searchLeads=${query.searchLeads || ''}&startLeads=${query.startLeads || ''}&endLeads=${query.endLeads || ''}&searchNews=${query.searchNews || ''}&startNews=${query.startNews || ''}&endNews=${query.endNews || ''}&tab=${currentTab}`;
        }
      %>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <% const estados=['Nuevo','Contactado','Negociacion','Cerrado']; %>
          <% estados.forEach(status=> { %>
            <div class="kanban-column flex flex-col bg-glass rounded-xl p-4 border border-white/10">

              <h3 class="font-bold mb-4 flex justify-between items-center text-lg border-b border-white/10 pb-2">
                <%= status %>
                  <span class="bg-black/30 text-xs px-2 py-1 rounded-full text-muted">
                    <%= board[status].total %>
                  </span>
              </h3>

              <div id="col-<%= status %>" data-status="<%= status %>" class="space-y-4 sortable-list flex-1">
                <% board[status].registros.forEach(s=> { %>
                  <div data-id="<%= s.id %>" class="p-4 rounded-lg bg-[#161f30] border border-white/5 cursor-grab active:cursor-grabbing hover:border-accent-1 transition-all group" onclick='openModal(<%- JSON.stringify(s).replace(/'/g, "\\'") %>)'>
                  <div class="flex justify-between items-start mb-2">
                    <p class="font-bold text-white group-hover:text-accent-1 transition"><%= s.nombre_completo %></p>
                    <div class="estado-circle w-2 h-2 rounded-full <%= status === 'Nuevo' ? 'bg-blue-500' : status === 'Contactado' ? 'bg-purple-500' : status === 'Negociacion' ? 'bg-yellow-500' : status === 'Cerrado' ? 'bg-green-500' : 'bg-gray-500' %>"></div>
                  </div>
                  <p class="text-xs text-muted mb-3 flex items-center gap-2">
                    <svg 
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 640 640"
                      class="w-5 h-5 inline-block align-middle"
                      fill="currentColor"
                    >
                      <path d="M112 128C85.5 128 64 149.5 64 176C64 191.1 71.1 205.3 83.2 214.4L291.2 370.4C308.3 383.2 331.7 383.2 348.8 370.4L556.8 214.4C568.9 205.3 576 191.1 576 176C576 149.5 554.5 128 528 128L112 128zM64 260L64 448C64 483.3 92.7 512 128 512L512 512C547.3 512 576 483.3 576 448L576 260L377.6 408.8C343.5 434.4 296.5 434.4 262.4 408.8L64 260z"/>
                    </svg>
                    <%= s.correo %>
                  </p>
                  <div class="flex justify-between items-center text-[10px] uppercase font-bold tracking-wider border-t border-white/10 pt-3">
                    <%
                      const interesLabels = {
                        Reinos: 'Reinos de Gondor',
                        Colinas: 'Colinas del Golf',
                        Inversion: 'Quiero ser inversionista',
                        Academia: 'Academia ALPEX'
                      };
                    %>

                    <span class="text-accent-2">
                      <%= interesLabels[s.interes_principal] %>
                    </span>
                    <span class="text-muted"><%= new Date(s.fecha_registro).toLocaleDateString() %></span>
                  </div>
                </div>
                <% }) %>
              </div>

              <% if (board[status].totalPages > 1) { %>
                <div class="flex justify-between items-center mt-4 pt-4 border-t border-white/10 text-xs">
                  <% if (board[status].page > 1) { %>
                    <a href="<%= getPageUrl(status, board[status].page - 1) %>" class="text-accent-1 hover:text-white">&laquo; Ant</a>
                  <% } else { %> <span class="text-white/20">&laquo; Ant</span> <% } %>
                  
                  <span class="text-muted">Pág <%= board[status].page %> de <%= board[status].totalPages %></span>
                  
                  <% if (board[status].page < board[status].totalPages) { %>
                    <a href="<%= getPageUrl(status, board[status].page + 1) %>" class="text-accent-1 hover:text-white">Sig &raquo;</a>
                  <% } else { %> <span class="text-white/20">Sig &raquo;</span> <% } %>
                </div>
              <% } %>

            </div>
            <% }) %>
      </div>
    </section>

    <section id="tab-newsletter" class="hidden">
      <form method="GET" action="/" class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8 bg-glass p-4 rounded-xl border border-white/10">
        <input type="hidden" name="tab" value="newsletter">
        
        <input type="hidden" name="searchLeads" value="<%= query.searchLeads || '' %>">
        <input type="hidden" name="startLeads" value="<%= query.startLeads || '' %>">
        <input type="hidden" name="endLeads" value="<%= query.endLeads || '' %>">
        
        <input type="text" name="searchNews" value="<%= query.searchNews || '' %>" placeholder="Buscar correo..." class="bg-black/20 border border-white/10 p-3 rounded-lg text-sm text-white outline-none focus:border-accent-1">
        <input type="date" name="startNews" value="<%= query.startNews || '' %>" class="bg-black/20 border border-white/10 p-3 rounded-lg text-sm text-muted outline-none focus:border-accent-1">
        <input type="date" name="endNews" value="<%= query.endNews || '' %>" class="bg-black/20 border border-white/10 p-3 rounded-lg text-sm text-muted outline-none focus:border-accent-1">
        
        <div class="flex gap-2">
          <button type="submit" class="flex-1 bg-accent text-black font-bold rounded-lg py-3 hover:bg-yellow-500 transition">Filtrar Newsletter</button>
          <% if(query.searchNews || query.startNews) { %>
            <a href="/?tab=newsletter" class="px-4 bg-white/10 text-white rounded-lg py-3 flex items-center hover:bg-white/20">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512" class="w-5 h-5 inline-block align-middle" fill="currentColor">
                <path d="M55.1 73.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3L147.2 256 9.9 393.4c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0L192.5 301.3 329.9 438.6c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L237.8 256 375.1 118.6c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L192.5 210.7 55.1 73.4z"/>
              </svg>
            </a>
          <% } %>
        </div>
      </form>

      <div class="bg-glass rounded-xl border border-white/10 overflow-hidden">
        <!-- Comienza la tabla -->
        <table class="w-full text-left">
          <thead class="bg-black/20 text-muted text-sm uppercase">
            <tr>
              <th class="p-5 font-medium">Correo Suscrito</th>
              <th class="p-5 font-medium">Fecha de Registro</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/5">
            <% newsletterData.registros.forEach(n=> { %>
              <tr class="hover:bg-white/5 transition">
                <td class="p-5 flex items-center gap-3">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" class="w-5 h-5 inline-block align-middle text-accent-1" fill="currentColor">
                    <path d="M112 128C85.5 128 64 149.5 64 176C64 191.1 71.1 205.3 83.2 214.4L291.2 370.4C308.3 383.2 331.7 383.2 348.8 370.4L556.8 214.4C568.9 205.3 576 191.1 576 176C576 149.5 554.5 128 528 128L112 128zM64 260L64 448C64 483.3 92.7 512 128 512L512 512C547.3 512 576 483.3 576 448L576 260L377.6 408.8C343.5 434.4 296.5 434.4 262.4 408.8L64 260z"/>
                  </svg>
                  <%= n.correo %>
                </td>
                <td class="p-5 text-muted">
                  <%= new Date(n.fecha_registro).toLocaleString('es-PE') %>
                </td>
              </tr>
              <% }) %>
          </tbody>
        </table>
      
        <!-- Barra de paginación -->
        <% if (newsletterData.totalPages> 1) { %>
          <div class="flex justify-between items-center mt-4 p-4 border-t border-white/10 text-sm bg-glass rounded-b-xl">
            <% if (newsletterData.page> 1) { %>
              <a href="<%= getPageUrl('Newsletter', newsletterData.page - 1) %>"
                class="text-accent-1 hover:text-white font-bold">&laquo; Anterior</a>
              <% } else { %>
                <span class="text-white/20">&laquo; Anterior</span>
                <% } %>
      
                  <span class="text-muted">Página <%= newsletterData.page %> de <%= newsletterData.totalPages %></span>
      
                  <% if (newsletterData.page < newsletterData.totalPages) { %>
                    <a href="<%= getPageUrl('Newsletter', newsletterData.page + 1) %>"
                      class="text-accent-1 hover:text-white font-bold">Siguiente &raquo;</a>
                    <% } else { %>
                      <span class="text-white/20">Siguiente &raquo;</span>
                      <% } %>
          </div>
          <% } %>
      </div>
    </section>

  </main>

  <div id="leadModal" class="fixed inset-0 z-50 hidden flex items-center justify-center 
            bg-black/70 backdrop-blur-sm opacity-0 transition-opacity duration-300 p-4">

    <div id="modalContent" class="bg-[var(--modal-bg)] border border-white/10 rounded-2xl 
              w-full max-w-2xl 
              max-h-[90vh] overflow-y-auto
              p-6 md:p-8 
              relative transform scale-95 transition-transform duration-300 shadow-2xl">

      <button onclick="closeModal()" class="absolute top-5 right-5 text-gray-400 hover:text-white text-xl">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512" class="w-5 h-5 inline-block align-middle" fill="currentColor">
          <path d="M55.1 73.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3L147.2 256 9.9 393.4c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0L192.5 301.3 329.9 438.6c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L237.8 256 375.1 118.6c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L192.5 210.7 55.1 73.4z"/>
        </svg>
      </button>

      <h2 id="modalName" class="text-3xl font-bold text-white mb-1">Nombre del Lead</h2>
      <p id="modalEmailSubtitle" class="text-muted text-sm mb-8 border-b border-white/10 pb-4">correo@ejemplo.com</p>

      <div class="grid grid-cols-2 gap-y-6 gap-x-4 mb-8">
        <div>
          <p class="text-muted text-xs flex items-center gap-2 mb-1">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" class="w-5 h-5 inline-block align-middle text-accent-1" fill="currentColor">
              <path d="M192 64C156.7 64 128 92.7 128 128L128 512C128 547.3 156.7 576 192 576L448 576C483.3 576 512 547.3 512 512L512 128C512 92.7 483.3 64 448 64L192 64zM288 416L352 416C396.2 416 432 451.8 432 496C432 504.8 424.8 512 416 512L224 512C215.2 512 208 504.8 208 496C208 451.8 243.8 416 288 416zM264 320C264 289.1 289.1 264 320 264C350.9 264 376 289.1 376 320C376 350.9 350.9 376 320 376C289.1 376 264 350.9 264 320zM280 128L360 128C373.3 128 384 138.7 384 152C384 165.3 373.3 176 360 176L280 176C266.7 176 256 165.3 256 152C256 138.7 266.7 128 280 128z"/>
            </svg>
            Estado</p>
          <p id="modalEstado" class="text-white font-medium">Lead Nuevo</p>
